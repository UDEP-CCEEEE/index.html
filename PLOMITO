<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Bot UDEP</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: #111b21;
}

#app {
  width: 360px;
  height: 640px;
  margin: 20px auto;
  background: #0b141a;
  border-radius: 15px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* HEADER */
#header {
  background: #202c33;
  color: white;
  padding: 12px;
  text-align: center;
  font-size: 14px;
}

/* CHAT SIN IMAGEN */
#chat {
  flex: 1;
  padding: 10px;
  overflow-y: auto;
  background: #0b141a;
}

/* MENSAJES */
.msg {
  max-width: 75%;
  margin: 5px 0;
  padding: 8px;
  border-radius: 8px;
  font-size: 14px;
}

.bot {
  background: #202c33;
  color: white;
}

.user {
  background: #005c4b;
  color: white;
  margin-left: auto;
}

.time {
  font-size: 10px;
  opacity: 0.7;
  margin-top: 3px;
  text-align: right;
}

.checks {
  font-size: 10px;
  margin-left: 5px;
  color: #53bdeb;
}

/* BOTONES */
.btn {
  display: block;
  width: 100%;
  padding: 8px;
  margin: 5px 0;
  border: none;
  border-radius: 6px;
  background: #00a884;
  color: white;
  cursor: pointer;
}

/* INPUT */
#inputArea {
  display: flex;
  background: #202c33;
}

#input {
  flex: 1;
  padding: 10px;
  border: none;
  outline: none;
  background: #2a3942;
  color: white;
}

button {
  background: #00a884;
  border: none;
  color: white;
  padding: 10px;
}

/* ESCRIBIENDO */
.typing {
  font-size: 12px;
  opacity: 0.7;
  margin: 5px 0;
}
</style>
</head>

<body>

<!-- 🔊 SONIDO (OPCIONAL, NO ROMPE SI FALLA) -->
<audio id="sonido">
  <source src="https://www.soundjay.com/buttons/sounds/button-3.mp3" type="audio/mpeg">
</audio>

<div id="app">

<div id="header">
  Universidad de Piura - Facultad de Empresas
</div>

<div id="chat"></div>

<div id="inputArea">
  <input id="input" placeholder="Escribe un mensaje">
  <button onclick="enviar()">➤</button>
</div>

</div>

<script>
const chat = document.getElementById("chat");

// 🔊 SONIDO (seguro)
function reproducirSonido() {
  const audio = document.getElementById("sonido");
  if (audio) {
    audio.currentTime = 0;
    audio.play().catch(() => {});
  }
}

// 🕒 HORA
function hora() {
  const d = new Date();
  return d.getHours().toString().padStart(2,'0') + ":" +
         d.getMinutes().toString().padStart(2,'0');
}

// 💬 MENSAJES
function mensajeBot(texto) {
  reproducirSonido();

  const div = document.createElement("div");
  div.className = "msg bot";
  div.innerHTML = texto + `<div class="time">${hora()}</div>`;
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

function mensajeUser(texto) {
  const div = document.createElement("div");
  div.className = "msg user";
  div.innerHTML = texto + `<div class="time">${hora()} <span class="checks">✔✔</span></div>`;
  chat.appendChild(div);
  chat.scrollTop = chat.scrollHeight;
}

// ✨ ESCRIBIENDO
function typingOn() {
  const div = document.createElement("div");
  div.className = "typing";
  div.id = "typing";
  div.innerText = "Escribiendo...";
  chat.appendChild(div);
}

function typingOff() {
  const t = document.getElementById("typing");
  if (t) t.remove();
}

// 🔘 BOTONES
function crearBoton(texto, valor) {
  const btn = document.createElement("button");
  btn.className = "btn";
  btn.innerText = texto;
  btn.onclick = () => manejar(valor);
  chat.appendChild(btn);
}

function limpiarBotones() {
  document.querySelectorAll(".btn").forEach(b => b.remove());
}

function mostrarMenu() {
  limpiarBotones();
  mensajeBot("Selecciona una opción:");

  crearBoton("1️⃣ Ventanilla", "1");
  crearBoton("2️⃣ Secretaría", "2");
  crearBoton("3️⃣ Sala de estudio", "3");
  crearBoton("4️⃣ Exámenes", "4");
  crearBoton("5️⃣ Anexo", "5");
  crearBoton("6️⃣ Fechas", "6");
}

function opciones() {
  limpiarBotones();
  crearBoton("Sí", "si");
  crearBoton("No", "no");
}

// 🔁 LÓGICA
function manejar(t) {
  mensajeUser(t);
  responder(t.toLowerCase());
}

function enviar() {
  const input = document.getElementById("input");
  const texto = input.value.trim();
  input.value = "";
  if (!texto) return;

  mensajeUser(texto);
  responder(texto.toLowerCase());
}

function responder(t) {

  limpiarBotones();
  typingOn();

  setTimeout(() => {
    typingOff();

    if (t.includes("hola")) {
      mensajeBot("Hola, soy el Bot de la facultad de empresas. ¿En qué puedo ayudarte?");
      mostrarMenu();
    }

    else if (t === "1") {
      mensajeBot("🕒 Ventanilla: 9:00 am - 12:30 pm y 4:00 pm - 6:30 pm.\n¿Otra opción?");
      opciones();
    }

    else if (t === "2") {
      mensajeBot("🕒 Secretaría: 10:00 am - 1:00 pm y 4:10 pm - 6:00 pm.\n¿Otra opción?");
      opciones();
    }

    else if (t === "3") {
      mensajeBot("🔗 Reserva: safcceee-piura@udep.edu.pe\n¿Otra opción?");
      opciones();
    }

    else if (t === "4") {
      mensajeBot("📄 Link de exámenes disponible.\n¿Otra opción?");
      opciones();
    }

    else if (t === "5") {
      mensajeBot("📞 Anexo: 3113\n¿Otra opción?");
      opciones();
    }

    else if (t === "6") {
      mensajeBot("📅 28 abril, 26 mayo, 06 junio.\n¿Otra opción?");
      opciones();
    }

    else if (t === "si" || t === "sí") {
      mostrarMenu();
    }

    else if (t === "no" || t.includes("gracias")) {
      mensajeBot("¡Muchas gracias, cuídate! 👋");
    }

    else {
      mensajeBot("Escribe 'Hola' para comenzar 😊");
    }

  }, 800);
}
</script>

</body>
</html>
